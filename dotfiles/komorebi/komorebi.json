{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.38/schema.json",
  "app_specific_configuration_path": "$Env:USERPROFILE/applications.json",
    "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "transparency": false,
  "transparency_alpha": 252,
  "default_workspace_padding": 10,
  "default_container_padding": 10,
  "border": true,

  "border_width": 4,
  "border_offset": -1,
  "mouse_follows_focus": true,
  "animation": {
    "enabled": true,
    "duration": 270,
    "fps": 300,
    "style": {
        "movement":"EaseOutBack",
        "transparency": "Linear"
      }
},
 "border_colours": {
    "single": "#cba6f7",
    "unfocused": "#45475a",
    "floating": "#f5c2e7",
    "monocle": "#b4befe"
  },
  "monitors": [
    // monitor 1, index 0
    {
      "workspaces": [
        {
          "name": "I",
          "layout": "BSP"
        },
        {
          "name": "II",
          "layout": "Grid"
        },
        {
          "name": "III",
          "layout": "UltrawideVerticalStack"
        }
      ]
    },
    // monitor 2, index 1
    {
      "workspaces": [
        {
          "name": "Home",
          "layout": "BSP"
        },
        {
          "name": "2",
          "layout": "Grid"
        },
        {
          "name": "3",
          "layout": "UltrawideVerticalStack"
        },
	
      ]
    }
  ],
 "ignore_rules": [
{
"kind": "Exe",
"id": "ACShadows.exe",
"matching_strategy": "Equals",
},
{
"kind": "Exe",
"id": "Overwatch.exe",
"matching_strategy": "Equals",
},
{
"kind": "Exe",
"id": "Photos.exe",
"matching_strategy": "Equals",
},
{
"kind": "Exe",
"id": "PotPlayerMini64.exe",
"matching_strategy": "Equals",
},
{
"kind": "Exe",
"id": "AmneziaVPN.exe",
"matching_strategy": "Equals",
}
]
}
